# OpenRouter API Configuration
# Get your provisioning key from: https://openrouter.ai/settings/provisioning-keys
OPENROUTER_API_KEY=your_provisioning_key_here

# PostgreSQL Catalog (required for DuckLake)
PG_PASSWORD=your_postgres_password

# S3/R2 Storage (required for DuckLake)
S3_KEY=your_s3_access_key
S3_SECRET=your_s3_secret_key

# AWS S3 Configuration (optional, for Docker Compose services)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# MinIO Configuration (optional, for MinIO export)
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_ENDPOINT=http://minio:9000

# Scheduler Configuration (optional)
TIMEZONE=UTC
S3_EXPORT_PATH=s3://my-bucket/backups/analytics.parquet
WEBHOOK_URL=https://hooks.example.com/analytics
